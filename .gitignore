*.txt filter:lfs diff=lfs merge=lfs -text

  # Secrets — never commit (use *.example templates)
  config/agents_config.json
  config/user_agents.json
  config/api_keys.json
  config/tg_*.json
  config/loader_cache.json
  replitperenos*.txt
  sessions/
  *.jsonl
  run_playerok.py
  run_zerogram.py
  patch_*.py
  fix_*.py
  test_*.py
  auto_test_runner.py
  extended_test_runner.py
  GITIGNORE_EOF

  # 2. Создаём agents_config.example.json
  cat > config/agents_config.example.json << 'EOF'
  {
    "agents": [
      {
        "id": "main-1",
        "name": "main-1",
        "provider": "openrouter",
        "model_id": "qwen/qwen3-coder:free",
        "api_key": "YOUR_OPENROUTER_KEY_HERE",
        "role": "general",
        "bio": "Default main agent",
        "active": true,
        "is_leading": true,
        "ctx_used_pct": 0.0
      }
    ]
  }
  EOF

  echo "gitignore updated and example created"
  git status --short 2>&1 | head -20
